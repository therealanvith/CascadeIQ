# Backend — real AIS training (choose ONE path)
# 1) Official MarineTraffic API (recommended). Get a key from MarineTraffic / Kpler data services.
MARINETRAFFIC_API_KEY=

# Map center used for AIS tile sampling (matches the MarineTraffic web map URL you shared:
# centerx:74.9 centery:14.7 zoom:4 — we sample API tiles around this center).
MARINETRAFFIC_CENTER_LAT=14.7
MARINETRAFFIC_CENTER_LON=74.9
# How many rings of 1°×1° tiles to query around the center (each tile respects MT area limits).
MARINETRAFFIC_RING_COUNT=2

# 2) OR provide a CSV you exported from a licensed AIS source with these columns:
# speed_deviation, weather_severity, port_congestion, distance_remaining, month, delay_hours
# AIS_TRAINING_CSV=
#
# Optional model output path
# MODEL_PATH=backend/model/vessel_delay_model.pkl

# Frontend
# NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
